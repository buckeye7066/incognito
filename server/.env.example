# Incognito optional backend — copy to .env and fill in. NEVER commit .env.
PORT=8787

# Twilio auth token (used ONLY to verify inbound webhook signatures).
TWILIO_AUTH_TOKEN=

# The public base URL Twilio is configured to call (used in signature checks).
PUBLIC_BASE_URL=http://localhost:8787

# Shared secret the app sends as X-Incognito-Secret for /events and /webhooks/email.
WEBHOOK_SHARED_SECRET=change-me-to-a-long-random-string

# CORS origin of your Incognito app (the web app's URL).
APP_ORIGIN=http://localhost:5173

# Message-body storage policy:
#   metadata  (default) — inbound SMS/email BODIES are NEVER persisted; only
#                         envelope metadata + a body length are stored.
#   encrypted          — bodies stored as opaque AES-256-GCM blobs (needs key).
#   plaintext          — discouraged; stores raw bodies.
STORE_MESSAGE_BODIES=metadata

# Used ONLY when STORE_MESSAGE_BODIES=encrypted. 64 hex chars (32 bytes) ideal;
# any passphrase is accepted (derived via SHA-256). If empty while mode is
# 'encrypted', the server safely falls back to metadata-only.
MESSAGE_ENCRYPTION_KEY=
